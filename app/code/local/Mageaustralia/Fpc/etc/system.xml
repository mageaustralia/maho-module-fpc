<config>
    <tabs>
        <mageaustralia translate="label">
            <label>Mage Australia</label>
            <sort_order>300</sort_order>
        </mageaustralia>
    </tabs>
    <sections>
        <mageaustralia_fpc translate="label">
            <label>Full Page Cache</label>
            <tab>mageaustralia</tab>
            <sort_order>20</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>
            <groups>
                <general translate="label" module="mageaustralia_fpc">
                    <label>General Settings</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label comment">
                            <label>Enable FPC</label>
                            <comment>When enabled, cacheable pages are saved as static HTML and served without PHP.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/enabled</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <lifetime translate="label comment">
                            <label>Cache Lifetime</label>
                            <comment>Seconds before cached pages expire. Default: 86400 (24 hours).</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/lifetime</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </lifetime>
                        <cdn_max_age translate="label comment">
                            <label>CDN Max-Age</label>
                            <comment>Cache-Control max-age in seconds for CDN layer. Default: 60.</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/cdn_max_age</config_path>
                            <sort_order>25</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </cdn_max_age>
                        <show_age translate="label comment">
                            <label>Show Cache Age Header</label>
                            <comment>Add X-FPC-Age response header showing cache entry age in seconds.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/show_age</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </show_age>
                        <customer_groups translate="label comment">
                            <label>Vary by Customer Group</label>
                            <comment>Include customer group in cache key. Different cached versions per group.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/customer_groups</config_path>
                            <sort_order>35</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </customer_groups>
                        <flush_on_product_save translate="label comment">
                            <label>Flush Product After Save</label>
                            <comment>Flush cached product page when a product is saved. Disable during bulk imports — changes will be flushed by cron within 1 minute.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/flush_on_product_save</config_path>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </flush_on_product_save>
                        <flush_on_stock_change translate="label comment">
                            <label>Flush Product After Inventory Change</label>
                            <comment>Flush cached product page when stock level changes. Disable during bulk stock sync — changes will be flushed by cron within 1 minute.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/flush_on_stock_change</config_path>
                            <sort_order>45</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </flush_on_stock_change>
                        <flush_button translate="label">
                            <label>Flush Full Page Cache</label>
                            <frontend_type>button</frontend_type>
                            <frontend_model>mageaustralia_fpc/adminhtml_system_config_flushButton</frontend_model>
                            <sort_order>90</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </flush_button>
                    </fields>
                </general>
                <pages translate="label" module="mageaustralia_fpc">
                    <label>Page Caching Rules</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>20</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <cache_actions translate="label comment">
                            <label>Cacheable Actions</label>
                            <comment>One full action name per line (e.g. catalog_product_view). Only these actions will be cached.</comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/cache_actions</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </cache_actions>
                        <refresh_actions translate="label comment">
                            <label>Refresh Actions</label>
                            <comment><![CDATA[One full action name per line. The <b>entire</b> FPC is flushed after these actions complete.<br/>
                            Usually not needed — cart/wishlist/compare changes are handled by Dynamic Blocks (AJAX),
                            and product/stock changes are handled by targeted purge observers.<br/>
                            Only use for custom actions that change rendered page content globally.]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/refresh_actions</config_path>
                            <sort_order>15</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </refresh_actions>
                        <bypass_handles translate="label comment">
                            <label>Bypass Layout Handles</label>
                            <comment>One handle per line. Pages with these handles will never be cached.</comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/bypass_handles</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </bypass_handles>
                        <uri_params translate="label comment">
                            <label>URI Parameters</label>
                            <comment>Query parameters included in cache key (one per line). All others are stripped.</comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/uri_params</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </uri_params>
                        <miss_uri_params translate="label comment">
                            <label>Strip Parameters</label>
                            <comment>Query parameters always stripped before cache key (one per line). UTM, gclid, etc.</comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/miss_uri_params</config_path>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </miss_uri_params>
                    </fields>
                </pages>
                <blocks translate="label" module="mageaustralia_fpc">
                    <label>Dynamic Blocks (AJAX Hole-Punching)</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>30</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <dynamic_blocks translate="label comment">
                            <label>Dynamic Blocks</label>
                            <comment><![CDATA[Configure blocks that are replaced with placeholders in cached HTML and loaded via AJAX.<br/>
                            <b>Block Type:</b> Maho block alias (e.g. <code>checkout/cart_sidebar</code>) or helper call (<code>helper:checkout/cart:getSummaryCount</code>)<br/>
                            <b>Template:</b> Optional phtml override (e.g. <code>checkout/cart/minicart.phtml</code>)<br/>
                            <b>Selector:</b> CSS selector to find in HTML (<code>#id</code>, <code>.class</code>, <code>[data-attr]</code>)]]></comment>
                            <frontend_type>text</frontend_type>
                            <frontend_model>mageaustralia_fpc/adminhtml_system_config_dynamicBlocks</frontend_model>
                            <backend_model>adminhtml/system_config_backend_serialized_array</backend_model>
                            <config_path>system/fpc/dynamic_blocks</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </dynamic_blocks>

                    </fields>
                </blocks>
                <turbo translate="label" module="mageaustralia_fpc">
                    <label>Turbo Drive (Instant Navigation)</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>40</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <turbo_enabled translate="label comment">
                            <label>Enable Turbo Drive</label>
                            <comment>Intercepts link clicks and replaces full page loads with fast AJAX navigation. Pages swap instantly without re-downloading CSS/JS.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/turbo_enabled</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </turbo_enabled>
                        <turbo_category translate="label comment">
                            <label>Category Pages</label>
                            <comment>Use Turbo for category browsing (recommended — biggest benefit).</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/turbo_category</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </turbo_category>
                        <turbo_product translate="label comment">
                            <label>Product Pages</label>
                            <comment>Use Turbo for product pages. Disable if swatches or configurable options break.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/turbo_product</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </turbo_product>
                        <turbo_cms translate="label comment">
                            <label>CMS Pages</label>
                            <comment>Use Turbo for CMS/static pages (homepage, about, etc.).</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/turbo_cms</config_path>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </turbo_cms>
                        <turbo_excluded_paths translate="label comment">
                            <label>Additional Excluded URL Paths</label>
                            <comment>Comma-separated URL path prefixes that always bypass Turbo. E.g. /checkout/,/customer/</comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/turbo_excluded_paths</config_path>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </turbo_excluded_paths>
                        <cart_qty_selector translate="label comment">
                            <label>Cart Qty Selector</label>
                            <comment><![CDATA[CSS selector(s) for elements that display the cart item count. Multiple selectors comma-separated.<br/>
                            e.g. <code>.skip-cart .count, .cart-toggle .badge</code>]]></comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/cart_qty_selector</config_path>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </cart_qty_selector>
                        <minicart_trigger_selector translate="label comment">
                            <label>Minicart Trigger Selector</label>
                            <comment><![CDATA[CSS selector for the element that opens the mini-cart. Clicking this fetches fresh cart HTML via AJAX.<br/>
                            e.g. <code>.skip-cart</code> or <code>.header-cart-wrapper</code>]]></comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/minicart_trigger_selector</config_path>
                            <sort_order>61</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </minicart_trigger_selector>
                        <minicart_content_selector translate="label comment">
                            <label>Minicart Content Selector</label>
                            <comment><![CDATA[CSS selector for the element whose innerHTML is replaced with fresh mini-cart HTML.<br/>
                            e.g. <code>.block-cart .block-content</code>]]></comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/minicart_content_selector</config_path>
                            <sort_order>62</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </minicart_content_selector>
                        <minicart_block translate="label comment">
                            <label>Minicart Layout Block</label>
                            <comment><![CDATA[Maho layout block name rendered by the minicart AJAX endpoint. Default: <code>cart_sidebar</code>]]></comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/minicart_block</config_path>
                            <sort_order>63</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </minicart_block>
                        <reset_remove_selectors translate="label comment">
                            <label>Reset: Remove Elements</label>
                            <comment><![CDATA[Comma-separated CSS selectors. Matching elements are <strong>removed from the DOM</strong> on Turbo navigation. Use for popup/overlay wrappers injected by JS libraries (Magnific Popup, modals, etc.).<br/>
                            Examples: <code>.mfp-bg, .mfp-wrap, .modal-backdrop, .aa-DetachedOverlay</code>]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/reset_remove_selectors</config_path>
                            <sort_order>64</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_remove_selectors>
                        <reset_close_selectors translate="label comment">
                            <label>Reset: Close Elements</label>
                            <comment><![CDATA[Comma-separated CSS selectors. The <code>open</code> class is <strong>removed</strong> from matching elements on Turbo navigation. Use for permanent page elements that toggle open/closed state.<br/>
                            Examples: <code>.meilisearch-autocomplete.open, .search-overlay.active</code>]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/reset_close_selectors</config_path>
                            <sort_order>65</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_close_selectors>
                        <reset_body_classes translate="label comment">
                            <label>Reset: Body Classes</label>
                            <comment><![CDATA[Comma-separated body classes that themes use to indicate "popup open" state. These will be <strong>removed</strong> from <code>&lt;body&gt;</code> on Turbo navigation.<br/>
                            Examples: <code>modal-open, no-scroll, overflow-hidden, mfp-zoom-out-cur</code>]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/reset_body_classes</config_path>
                            <sort_order>66</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_body_classes>
                        <reset_clear_inputs translate="label comment">
                            <label>Reset: Clear Input Selectors</label>
                            <comment><![CDATA[Comma-separated CSS selectors for input elements that should have their value cleared on Turbo navigation (e.g. search inputs).<br/>
                            Examples: <code>.meilisearch-search-input, .search-input</code>]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/reset_clear_inputs</config_path>
                            <sort_order>67</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_clear_inputs>
                        <reset_clone_selectors translate="label comment">
                            <label>Reset: Clone Elements (Strip Listeners)</label>
                            <comment><![CDATA[Comma-separated CSS selectors for elements that should be cloned-and-replaced on Turbo navigation. Cloning strips all JavaScript event listeners — essential for third-party libraries (like Meilisearch) that re-attach listeners on every init, causing AJAX request buildup.<br/>
                            Examples: <code>.meilisearch-search-input, .algolia-search-input</code>]]></comment>
                            <frontend_type>textarea</frontend_type>
                            <config_path>system/fpc/reset_clone_selectors</config_path>
                            <sort_order>67</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_clone_selectors>
                        <reset_dispatch_escape translate="label comment">
                            <label>Reset: Dispatch ESC Key</label>
                            <comment>Dispatch an ESC keydown event on Turbo navigation. Most popup libraries close on ESC — this is the universal "close everything" trigger.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/reset_dispatch_escape</config_path>
                            <sort_order>68</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </reset_dispatch_escape>
                    </fields>
                </turbo>
                <warmup translate="label" module="mageaustralia_fpc">
                    <label>Cache Warmup</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>50</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <warmup_enabled translate="label comment">
                            <label>Enable Cache Warmup</label>
                            <comment>After a full FPC flush, automatically crawl sitemap URLs to pre-populate the cache.</comment>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <config_path>system/fpc/warmup_enabled</config_path>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </warmup_enabled>
                        <warmup_batch_size translate="label comment">
                            <label>URLs Per Cron Run</label>
                            <comment>Maximum URLs to warm per cron execution (runs every minute). Large sitemaps are spread across multiple runs.</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/warmup_batch_size</config_path>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </warmup_batch_size>
                        <warmup_delay_ms translate="label comment">
                            <label>Delay Between Requests (ms)</label>
                            <comment>Milliseconds to wait between requests. Prevents server overload. 0 = no delay, 100 = recommended.</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/warmup_delay_ms</config_path>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </warmup_delay_ms>
                        <warmup_sitemap_path translate="label comment">
                            <label>Sitemap Path</label>
                            <comment>Path to sitemap.xml (relative to web root, e.g. "sitemap.xml"). Leave empty to auto-detect from Catalog > Sitemap config.</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/warmup_sitemap_path</config_path>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </warmup_sitemap_path>
                        <warmup_basic_auth translate="label comment">
                            <label>Basic Auth (staging only)</label>
                            <comment>If the site requires HTTP basic auth (e.g. staging), enter as user:password. Leave empty for production.</comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/warmup_basic_auth</config_path>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </warmup_basic_auth>
                        <warmup_schedule translate="label comment">
                            <label>Scheduled Warmup (Cron)</label>
                            <comment><![CDATA[Optional cron expression to run warmup on a schedule (e.g. <code>0 */6 * * *</code> for every 6 hours). Leave empty to only warm after flushes. Only re-crawls URLs whose cache files are older than the cache lifetime.]]></comment>
                            <frontend_type>text</frontend_type>
                            <config_path>system/fpc/warmup_schedule</config_path>
