        <?php if ($barCount > 0 && $maxVal > 0): ?>
            <div class="fpc-chart-wrap" style="overflow-x:auto;">
                <svg viewBox="0 0 <?php echo $chartW; ?> <?php echo $chartH; ?>" preserveAspectRatio="xMidYMid meet" style="display:block;width:100%;height:auto;">
                    <!-- Y-axis gridlines -->
                    <?php for ($g = 0; $g <= 4; $g++): ?>
