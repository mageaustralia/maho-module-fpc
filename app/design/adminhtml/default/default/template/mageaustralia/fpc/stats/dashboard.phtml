    .fpc-dash .fpc-chart-legend { display: flex; gap: 20px; margin-bottom: 12px; }
    .fpc-dash .fpc-legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #6b7280; }
    .fpc-dash .fpc-legend-dot { width: 10px; height: 10px; border-radius: 2px; }

    .fpc-dash table { width: 100%; border-collapse: collapse; font-size: 13px; }
