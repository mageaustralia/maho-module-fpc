        .fpc-dash .fpc-grid-2 { grid-template-columns: 1fr; }
    }
</style>

<div class="fpc-dash">
    <div class="fpc-period-bar">
        <div>
            <h2>FPC Statistics</h2>
            <p class="fpc-subtitle"><?php echo $this->escapeHtml($periodLabel); ?></p>
        </div>
        <div class="fpc-period-btns">
            <?php foreach ($periodOpts as $opt): ?>
                <a href="<?php echo $this->getPeriodUrl($opt['hours']); ?>"
                   class="fpc-period-btn <?php echo $opt['active'] ? 'active' : ''; ?>">
                    <?php echo $this->escapeHtml($opt['label']); ?>
                </a>
            <?php endforeach; ?>
        </div>
    </div>

    <?php if (!$fpcEnabled): ?>
        <div class="fpc-alert fpc-alert-warn">
            <strong>FPC is disabled.</strong>
            No pages are being cached. <a href="<?php echo $this->getConfigUrl(); ?>">Enable it in configuration.</a>
        </div>
    <?php endif; ?>

    <?php if (!$statsEnabled): ?>
        <div class="fpc-alert fpc-alert-info">
            <strong>Statistics collection is disabled.</strong>
            Data shown may be stale. <a href="<?php echo $this->getConfigUrl(); ?>">Enable statistics tracking.</a>
        </div>
    <?php endif; ?>

    <!-- Stat Cards -->
    <div class="fpc-cards">
        <div class="fpc-card">
            <div class="fpc-card-accent fpc-card-accent-green"></div>
            <div class="fpc-card-label">Hit Rate</div>
            <div class="fpc-card-value"><?php echo number_format($hitRate['rate'], 1); ?>%</div>
            <div class="fpc-card-sub"><?php echo number_format($hitRate['hits']); ?> hits / <?php echo number_format($hitRate['total']); ?> total</div>
        </div>
        <div class="fpc-card">
            <div class="fpc-card-accent fpc-card-accent-blue"></div>
            <div class="fpc-card-label">Total Requests</div>
            <div class="fpc-card-value"><?php echo number_format($hitRate['total']); ?></div>
            <div class="fpc-card-sub"><?php echo number_format($hitRate['misses']); ?> misses</div>
        </div>
        <div class="fpc-card">
            <div class="fpc-card-accent fpc-card-accent-amber"></div>
            <div class="fpc-card-label">Avg TTFB</div>
            <div class="fpc-card-value"><?php echo number_format($avgTtfb, 0); ?><span style="font-size:16px;font-weight:400;color:#9ca3af;">ms</span></div>
            <div class="fpc-card-sub">Client-side TTFB (all pages)</div>
        </div>
        <div class="fpc-card">
            <div class="fpc-card-accent fpc-card-accent-red"></div>
            <div class="fpc-card-label">Cache Flushes</div>
            <div class="fpc-card-value"><?php echo number_format($flushCount); ?></div>
            <div class="fpc-card-sub">Full or partial flushes</div>
        </div>
    </div>

    <!-- Chart: Hit/Miss Over Time -->
    <div class="fpc-section">
        <h3 class="fpc-section-title">Hits vs Misses Over Time</h3>
        <div class="fpc-chart-legend">
            <span class="fpc-legend-item"><span class="fpc-legend-dot" style="background:#10b981;"></span> Hits</span>
            <span class="fpc-legend-item"><span class="fpc-legend-dot" style="background:#ef4444;"></span> Misses</span>
        </div>
        <?php if ($barCount > 0 && $maxVal > 0): ?>
            <div style="overflow-x:auto;">
                <svg width="<?php echo $chartW; ?>" height="<?php echo $chartH; ?>" viewBox="0 0 <?php echo $chartW; ?> <?php echo $chartH; ?>" style="display:block;max-width:100%;">
                    <!-- Y-axis gridlines -->
                    <?php for ($g = 0; $g <= 4; $g++): ?>
                        <?php
                        $yVal = ($niceMax / 4) * $g;
                        $yPos = $chartPadT + $plotH - ($plotH * ($yVal / $niceMax));
                        ?>
                        <line x1="<?php echo $chartPadL; ?>" y1="<?php echo $yPos; ?>"
                              x2="<?php echo $chartW - $chartPadR; ?>" y2="<?php echo $yPos; ?>"
                              stroke="#e5e7eb" stroke-width="1" />
                        <text x="<?php echo $chartPadL - 8; ?>" y="<?php echo $yPos + 4; ?>"
                              text-anchor="end" font-size="11" fill="#9ca3af">
                            <?php echo number_format($yVal, 0); ?>
                        </text>
                    <?php endfor; ?>

                    <!-- Bars -->
                    <?php
                    $gap = 2;
                    $barW = max(2, ($plotW / max(1, $barCount)) - $gap);
                    $halfBar = $barW / 2;
                    foreach ($hourlyStats as $i => $bucket):
                        $x = $chartPadL + ($i * ($barW + $gap));
                        $hitsH = ($bucket['hits'] / $niceMax) * $plotH;
                        $missH = ($bucket['misses'] / $niceMax) * $plotH;
                        $totalH = $hitsH + $missH;
                        $barBase = $chartPadT + $plotH;
                    ?>
                        <!-- Miss bar (bottom) -->
                        <?php if ($missH > 0): ?>
                            <rect x="<?php echo $x; ?>" y="<?php echo $barBase - $missH; ?>"
                                  width="<?php echo $barW; ?>" height="<?php echo $missH; ?>"
                                  fill="#ef4444" rx="1">
                                <title><?php echo $this->escapeHtml($bucket['hour']); ?> - Misses: <?php echo $bucket['misses']; ?></title>
                            </rect>
                        <?php endif; ?>
                        <!-- Hit bar (stacked on top) -->
                        <?php if ($hitsH > 0): ?>
                            <rect x="<?php echo $x; ?>" y="<?php echo $barBase - $totalH; ?>"
                                  width="<?php echo $barW; ?>" height="<?php echo $hitsH; ?>"
                                  fill="#10b981" rx="1">
                                <title><?php echo $this->escapeHtml($bucket['hour']); ?> - Hits: <?php echo $bucket['hits']; ?></title>
                            </rect>
                        <?php endif; ?>
                        <!-- X-axis label (show every Nth) -->
                        <?php
                        $labelInterval = max(1, (int) floor($barCount / 8));
                        if ($i % $labelInterval === 0):
                            $label = substr($bucket['hour'], 11, 5); // HH:00
                            if ($periodHours >= 168) {
                                $label = substr($bucket['hour'], 5, 5); // MM-DD
                            }
                        ?>
                            <text x="<?php echo $x + $halfBar; ?>" y="<?php echo $chartH - 8; ?>"
                                  text-anchor="middle" font-size="10" fill="#9ca3af">
                                <?php echo $this->escapeHtml($label); ?>
                            </text>
                        <?php endif; ?>
                    <?php endforeach; ?>
                </svg>
            </div>
        <?php else: ?>
            <div class="fpc-empty">No data available for this period.</div>
        <?php endif; ?>
    </div>

    <!-- Tables: Top Missed URLs + Recent Flushes -->
    <div class="fpc-grid-2">
        <div class="fpc-section">
            <h3 class="fpc-section-title">Top Missed URLs</h3>
            <?php if (!empty($topMissed)): ?>
                <table>
                    <thead>
                        <tr>
                            <th>URL Path</th>
                            <th style="text-align:right;">Miss Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($topMissed as $row): ?>
                            <tr>
                                <td class="fpc-url">/<?php echo $this->escapeHtml($row['url_path']); ?></td>
                                <td class="fpc-count"><?php echo number_format((int)$row['miss_count']); ?></td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            <?php else: ?>
                <div class="fpc-empty">No misses recorded.</div>
            <?php endif; ?>
        </div>

        <div class="fpc-section">
            <h3 class="fpc-section-title">Recent Flushes</h3>
            <?php if (!empty($recentFlush)): ?>
                <table>
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Reason</th>
                            <th>Store</th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($recentFlush as $row): ?>
                            <tr>
                                <td class="fpc-time"><?php echo $this->escapeHtml($row['created_at']); ?></td>
                                <td class="fpc-reason"><?php echo $this->escapeHtml($row['flush_reason'] ?? '-'); ?></td>
                                <td class="fpc-store"><?php echo $this->escapeHtml($row['store_code'] ?? '-'); ?></td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            <?php else: ?>
                <div class="fpc-empty">No flushes recorded.</div>
            <?php endif; ?>
        </div>
    </div>
</div>
