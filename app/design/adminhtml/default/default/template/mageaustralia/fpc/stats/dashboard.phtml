<script>
(function() {
    'use strict';

    // Create a single tooltip element and append to body
    var tooltip = document.createElement('div');
    tooltip.className = 'fpc-tooltip';
    document.body.appendChild(tooltip);

    function buildTooltipHtml(el) {
        var time = el.getAttribute('data-fpc-time') || '';
        var label = el.getAttribute('data-fpc-label') || '';
        var value = el.getAttribute('data-fpc-value') || '';
        var extraLabel = el.getAttribute('data-fpc-extra-label') || '';
        var extraValue = el.getAttribute('data-fpc-extra-value') || '';
        var color = el.getAttribute('data-fpc-color') || '#3b82f6';

        var html = '<div class="fpc-tooltip-time">' + time + '</div>';
        html += '<div><span class="fpc-tooltip-label" style="color:' + color + '">' + label + ':</span><strong>' + value + '</strong></div>';
        if (extraLabel) {
            html += '<div><span class="fpc-tooltip-label">' + extraLabel + ':</span><strong>' + extraValue + '</strong></div>';
        }
        return html;
    }

    function positionTooltip(evt) {
        // Position above cursor (viewport-relative since tooltip is position:fixed)
        tooltip.style.left = evt.clientX + 'px';
        tooltip.style.top = evt.clientY + 'px';
    }

    // Delegate from .fpc-dash container
    var dash = document.querySelector('.fpc-dash');
    if (!dash) return;

    dash.addEventListener('mouseover', function(e) {
        var target = e.target.closest('[data-fpc-tip]');
        if (!target) return;
        tooltip.innerHTML = buildTooltipHtml(target);
        tooltip.classList.add('visible');
        positionTooltip(e);
    });

    dash.addEventListener('mousemove', function(e) {
        if (!tooltip.classList.contains('visible')) return;
        positionTooltip(e);
    });

    dash.addEventListener('mouseout', function(e) {
        var target = e.target.closest('[data-fpc-tip]');
        if (!target) return;
        // If moving to a child, don't hide
        if (target.contains(e.relatedTarget)) return;
        tooltip.classList.remove('visible');
    });
})();
</script>
