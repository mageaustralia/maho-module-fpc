        <?php
        $hasTtfbData = false;
        foreach ($hourlyTtfb as $t) {
            if ($t['avg_ttfb'] > 0) {
                $hasTtfbData = true;
                break;
            }
        }
        ?>
        <?php if ($ttfbCount > 0 && $hasTtfbData): ?>
            <div class="fpc-chart-wrap" style="overflow-x:auto;">
                <svg viewBox="0 0 <?php echo $chartW; ?> <?php echo $chartH; ?>" preserveAspectRatio="xMidYMid meet" style="display:block;width:100%;height:auto;">
                    <!-- Y-axis gridlines -->
                    <?php for ($g = 0; $g <= 4; $g++): ?>
                        <?php
                        $yVal = ($niceTtfbMax / 4) * $g;
                        $yPos = $chartPadT + $plotH - ($plotH * ($yVal / $niceTtfbMax));
                        ?>
                        <line x1="<?php echo $chartPadL; ?>" y1="<?php echo $yPos; ?>"
                              x2="<?php echo $chartW - $chartPadR; ?>" y2="<?php echo $yPos; ?>"
                              stroke="#e5e7eb" stroke-width="1" />
                        <text x="<?php echo $chartPadL - 8; ?>" y="<?php echo $yPos + 4; ?>"
                              text-anchor="end" font-size="11" fill="#9ca3af">
                            <?php echo number_format($yVal, 0); ?>ms
                        </text>
                    <?php endfor; ?>

                    <!-- P95 TTFB line (draw first so avg line is on top) -->
                    <?php
                    $stepW = $plotW / max(1, $ttfbCount - 1);
                    $p95Points = [];
                    $avgPoints = [];
                    foreach ($hourlyTtfb as $i => $bucket):
                        $x = $chartPadL + ($i * $stepW);
                        if ($bucket['p95_ttfb'] > 0) {
                            $y = $chartPadT + $plotH - (($bucket['p95_ttfb'] / $niceTtfbMax) * $plotH);
                            $p95Points[] = round($x, 1) . ',' . round($y, 1);
                        }
                        if ($bucket['avg_ttfb'] > 0) {
                            $y = $chartPadT + $plotH - (($bucket['avg_ttfb'] / $niceTtfbMax) * $plotH);
                            $avgPoints[] = round($x, 1) . ',' . round($y, 1);
                        }
                    endforeach;
                    ?>

                    <?php if (count($p95Points) > 1): ?>
                        <polyline points="<?php echo implode(' ', $p95Points); ?>"
                                  fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.7" />
                    <?php endif; ?>

                    <?php if (count($avgPoints) > 1): ?>
                        <polyline points="<?php echo implode(' ', $avgPoints); ?>"
                                  fill="none" stroke="#3b82f6" stroke-width="2" />
                    <?php endif; ?>

                    <!-- Data point dots + tooltips for avg -->
                    <?php foreach ($hourlyTtfb as $i => $bucket):
                        if ($bucket['avg_ttfb'] <= 0) continue;
                        $x = $chartPadL + ($i * $stepW);
                        $y = $chartPadT + $plotH - (($bucket['avg_ttfb'] / $niceTtfbMax) * $plotH);
                    ?>
                        <circle cx="<?php echo round($x, 1); ?>" cy="<?php echo round($y, 1); ?>"
                                r="6" fill="#3b82f6" opacity="0.8"
                                data-fpc-tip="1"
                                data-fpc-time="<?php echo $this->escapeHtml($bucket['hour']); ?>"
                                data-fpc-label="Avg"
                                data-fpc-value="<?php echo round($bucket['avg_ttfb']); ?>ms"
                                data-fpc-extra-label="P95"
                                data-fpc-extra-value="<?php echo $bucket['p95_ttfb']; ?>ms"
                                data-fpc-color="#3b82f6" />
                    <?php endforeach; ?>

                    <!-- X-axis labels -->
                    <?php
                    $labelInterval = max(1, (int) floor($ttfbCount / 8));
                    foreach ($hourlyTtfb as $i => $bucket):
                        if ($i % $labelInterval !== 0) continue;
                        $x = $chartPadL + ($i * $stepW);
                        $label = substr($bucket['hour'], 11, 5);
                        if ($periodHours >= 168) {
                            $label = substr($bucket['hour'], 5, 5);
