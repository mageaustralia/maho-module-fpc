<?php
/**
 * Mageaustralia_Fpc — FPC Statistics Dashboard
 *
 * @var Mageaustralia_Fpc_Block_Adminhtml_Stats_Dashboard $this
 */

$hitRate      = $this->getHitRate();
$flushCount   = $this->getFlushCount();
$avgTtfb      = $this->getAverageTtfb();
$topMissed    = $this->getTopMissedUrls();
$recentFlush  = $this->getRecentFlushes();
$hourlyStats  = $this->getHourlyStats();
$hourlyTtfb   = $this->getHourlyTtfb();
$periodHours  = $this->getPeriodHours();
$periodLabel  = $this->getPeriodLabel();
$periodOpts   = $this->getPeriodOptions();
$storeOpts    = $this->getStoreOptions();
$storeFilter  = $this->getStoreFilter();
$statsEnabled = $this->isStatsEnabled();
$fpcEnabled   = $this->isFpcEnabled();

// Hit/Miss chart dimensions
$chartW      = 800;
$chartH      = 200;
$chartPadL   = 50;
$chartPadR   = 20;
$chartPadT   = 20;
$chartPadB   = 40;
$plotW       = $chartW - $chartPadL - $chartPadR;
$plotH       = $chartH - $chartPadT - $chartPadB;
$barCount    = count($hourlyStats);
$maxVal      = 1;
foreach ($hourlyStats as $h) {
    $total = $h['hits'] + $h['misses'];
    if ($total > $maxVal) {
        $maxVal = $total;
    }
}
$niceMax = (int) (ceil($maxVal / max(1, pow(10, floor(log10(max(1, $maxVal))) - 1))) * max(1, pow(10, floor(log10(max(1, $maxVal))) - 1)));
if ($niceMax < 1) {
    $niceMax = 1;
}

// TTFB chart dimensions
$ttfbCount = count($hourlyTtfb);
$maxTtfb   = 1;
foreach ($hourlyTtfb as $t) {
    $val = max($t['avg_ttfb'], $t['p95_ttfb']);
    if ($val > $maxTtfb) {
        $maxTtfb = $val;
    }
}
$niceTtfbMax = (int) (ceil($maxTtfb / max(1, pow(10, floor(log10(max(1, $maxTtfb))) - 1))) * max(1, pow(10, floor(log10(max(1, $maxTtfb))) - 1)));
if ($niceTtfbMax < 1) {
    $niceTtfbMax = 1;
}
