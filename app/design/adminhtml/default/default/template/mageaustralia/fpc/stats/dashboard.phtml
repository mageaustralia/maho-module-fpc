                    <!-- Bars -->
                    <?php
                    $gap = 2;
                    $barW = max(2, ($plotW / max(1, $barCount)) - $gap);
                    $halfBar = $barW / 2;
                    foreach ($hourlyStats as $i => $bucket):
                        $x = $chartPadL + ($i * ($barW + $gap));
                        $hitsH = ($bucket['hits'] / $niceMax) * $plotH;
                        $missH = ($bucket['misses'] / $niceMax) * $plotH;
                        $totalH = $hitsH + $missH;
                        $barBase = $chartPadT + $plotH;
                    ?>
                        <!-- Miss bar (bottom) -->
                        <?php if ($missH > 0): ?>
