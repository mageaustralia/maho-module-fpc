<layout version="0.1.0">
    <default>
        <reference name="head">
            <!-- FPC config (outputs window.FPC_CONFIG with admin-configured selectors) -->
            <block type="mageaustralia_fpc/config" name="fpc.config" before="-" />

            <!-- FPC scripts -->
            <action method="addJs">
                <script>mageaustralia/fpc/loader.js</script>
            </action>
            <action method="addJs">
                <script>mageaustralia/fpc/ajax-cart.js</script>
            </action>

            <!-- Turbo Drive (outputs script tag only when enabled in config) -->
            <block type="mageaustralia_fpc/turbo" name="fpc.turbo" after="-" />
        </reference>
    </default>

    <!--
        DynamicController layout — minimal: just load default blocks
        so the controller can render cart_count, welcome, messages, etc.
    -->
    <fpc_dynamic_index>
        <reference name="root">
            <action method="setTemplate">
                <template>page/empty.phtml</template>
            </action>
        </reference>
    </fpc_dynamic_index>
</layout>
